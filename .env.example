# MongoDB
MONGODB_URI=mongodb://mongodb:27017/youtube-bot

# Uygulama
PORT=3000
NODE_ENV=production
CRON_SCHEDULE=*/30 * * * *
DOWNLOAD_DIR=/app/downloads
MERGED_DIR=/app/merged
LOG_LEVEL=info

# Instagram kaynakları (virgülle ayrılmış profil URL'leri veya tek post URL'leri)
INSTAGRAM_SOURCES=https://www.instagram.com/example_user/

# YouTube OAuth2
YOUTUBE_CLIENT_ID=your_client_id
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/auth/youtube/callback
YOUTUBE_REFRESH_TOKEN=your_refresh_token

# YouTube yükleme ayarları
YOUTUBE_DEFAULT_TITLE=Instagram Video Derlemesi
YOUTUBE_DEFAULT_DESCRIPTION=Instagram'dan otomatik olarak derlenmiş video.
YOUTUBE_DEFAULT_TAGS=instagram,compilation,auto
YOUTUBE_DEFAULT_PRIVACY=private
YOUTUBE_DEFAULT_CATEGORY_ID=22
